# ---- 旧 CLI 批处理配置 ----
# 企业微信机器人 Webhook（必填，覆盖 config.yaml）
PUSHER_WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# ---- 新 AI 助手服务配置 ----
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
WECOM_WEBHOOK_URL=
TZ=Asia/Shanghai
# RSS 订阅源（多个用英文逗号分隔）
NEWS_RSS_URLS=https://www.qbitai.com/feed
# HuggingFace 代理（Docker 内必须用 host.docker.internal，不能写 127.0.0.1）
HF_PROXY=http://host.docker.internal:8899
# 将 HuggingFace 视为可选源；开启后超时只记 skipped，不污染 health 失败状态
HF_OPTIONAL=0

# ---- AI RSS 多源配置 ----
# 追加默认 AI 源；若改成 replace，则只使用下列配置
AI_RSS_MODE=append
AI_RSS_FEEDS=
